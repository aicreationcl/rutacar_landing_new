# URL real de producción, sin slash final. Usada por metadata, sitemap.xml y robots.txt.
# LA-2026-028: verificar con curl contra la URL real antes de cerrar el incremento.
NEXT_PUBLIC_SITE_URL=https://rutacar.cl

# Property ID de Google Analytics 4 (formato G-XXXXXXX). Sin este valor, Analytics.tsx
# no carga ningún script — no se debe rellenar con un ID inventado o de otro proyecto.
NEXT_PUBLIC_GA_ID=

# Código de verificación de Google Search Console (meta tag, no el archivo HTML).
# Se obtiene en search.google.com/search-console al agregar la propiedad del dominio real.
NEXT_PUBLIC_GSC_VERIFICATION=

# --- Incremento 02 · Cotizador (proxy server-to-server) ---
# Server-only (sin prefijo NEXT_PUBLIC_): el backend rutacar_landing_back nunca
# debe ser alcanzable desde el navegador. Ver app/api/cotizaciones/route.ts.
BACKEND_API_URL=
BACKEND_API_KEY=

